# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (used for SEO: sitemap, Open Graph, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://catchcolumbus.com

# Google Analytics — get from analytics.google.com (GA4 Measurement ID)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Resend — get from resend.com (for sending emails)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
